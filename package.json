    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.4",
    "fast-check": "^4.7.0",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
