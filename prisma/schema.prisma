generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Article {
  id          String            @id @db.Char(26)
  tenantId    String            @map("tenant_id") @db.Char(26)
  title       String            @db.VarChar(100)
  content     String
  status      String            @default("draft") @db.VarChar(20)
  slug        String            @db.VarChar(200)
  authorId    String            @map("author_id") @db.Char(26)
  viewCount   Int               @default(0) @map("view_count")
  likeCount   Int               @default(0) @map("like_count")
  publishedAt DateTime?         @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  bookmarks   ArticleBookmark[]
  likes       ArticleLike[]
  tags        ArticleTag[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, authorId])
  @@index([tenantId, status, publishedAt])
  @@index([tenantId, status, viewCount])
  @@index([tenantId, status, likeCount])
  @@map("articles")
}

model Tag {
  id             String   @id @db.Char(26)
  tenantId       String   @map("tenant_id") @db.Char(26)
  name           String   @db.VarChar(50)
  normalizedName String   @map("normalized_name") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([tenantId, normalizedName])
  @@index([tenantId])
  @@map("tags")
}

model ArticleTag {
  articleId String   @map("article_id") @db.Char(26)
  tagId     String   @map("tag_id") @db.Char(26)
  tenantId  String   @map("tenant_id") @db.Char(26)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tenantId, tagId])
  @@map("article_tags")
}

model ArticleLike {
  articleId String   @map("article_id") @db.Char(26)
  userId    String   @map("user_id") @db.Char(26)
  tenantId  String   @map("tenant_id") @db.Char(26)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([articleId, userId])
  @@index([tenantId, articleId])
  @@map("article_likes")
}

model ArticleBookmark {
  articleId String   @map("article_id") @db.Char(26)
  userId    String   @map("user_id") @db.Char(26)
  tenantId  String   @map("tenant_id") @db.Char(26)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([articleId, userId])
  @@index([tenantId, userId, createdAt])
  @@map("article_bookmarks")
}

// スキルシート関連モデル
model SkillSheet {
  id               String    @id @db.Char(26)
  tenantId         String    @map("tenant_id") @db.Char(26)
  userId           String    @map("user_id") @db.Char(26)
  fullName         String    @map("project_name") @db.VarChar(255)
  gender           String    @map("scale") @db.VarChar(50)
  birthDate        DateTime? @map("birth_date") @db.Date
  nationality      String    @default("") @db.VarChar(100)
  stationLine      String    @default("") @map("station_line") @db.VarChar(100)
  nearestStation   String    @default("") @map("nearest_station") @db.VarChar(100)
  desiredStartDate DateTime  @map("start_date") @db.Date
  desiredArea      String    @default("") @map("desired_area") @db.VarChar(255)
  experienceMonths Int       @map("duration_months")
  selfPr           String    @map("self_introduction") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  projects SkillSheetProject[]

  @@index([tenantId, userId])
  @@index([userId])
  @@map("skill_sheets")
}

model SkillSheetProject {
  id            String   @id @db.Char(26)
  skillSheetId  String   @map("skill_sheet_id") @db.Char(26)
  projectNumber Int      @map("project_number")
  periodStart   String   @map("period_start") @db.VarChar(100) // 2025年7月など
  periodEnd     String   @map("period_end") @db.VarChar(100)
  description   String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  skillSheet   SkillSheet              @relation(fields: [skillSheetId], references: [id], onDelete: Cascade)
  tasks        SkillSheetProjectTask[]
  skills       SkillSheetSkill[]
  environments SkillSheetEnvironment[]

  @@index([skillSheetId])
  @@map("skill_sheet_projects")
}

model SkillSheetProjectTask {
  id                  String   @id @db.Char(26)
  skillSheetProjectId String   @map("skill_sheet_project_id") @db.Char(26)
  category            String   @db.VarChar(100) // 要件分析/設計/開発/テスト等
  taskDescription     String   @map("task_description") @db.Text
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  project SkillSheetProject @relation(fields: [skillSheetProjectId], references: [id], onDelete: Cascade)

  @@index([skillSheetProjectId])
  @@map("skill_sheet_project_tasks")
}

model SkillSheetSkill {
  id                  String   @id @db.Char(26)
  skillSheetProjectId String   @map("skill_sheet_project_id") @db.Char(26)
  category            String   @db.VarChar(50) // 言語/FW/インフラ/ツール/OS
  skillName           String   @map("skill_name") @db.VarChar(100)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project SkillSheetProject @relation(fields: [skillSheetProjectId], references: [id], onDelete: Cascade)

  @@index([skillSheetProjectId])
  @@index([skillSheetProjectId, category])
  @@map("skill_sheet_skills")
}

model SkillSheetEnvironment {
  id                  String   @id @db.Char(26)
  skillSheetProjectId String   @map("skill_sheet_project_id") @db.Char(26)
  environmentType     String   @map("environment_type") @db.VarChar(50) // OS/Tool/Framework
  value               String   @db.VarChar(100)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project SkillSheetProject @relation(fields: [skillSheetProjectId], references: [id], onDelete: Cascade)

  @@index([skillSheetProjectId])
  @@index([skillSheetProjectId, environmentType])
  @@map("skill_sheet_environments")
}

model Profile {
  id           String   @id @db.Char(26)
  userId       String   @unique @map("user_id") @db.Char(26)
  tenantId     String   @map("tenant_id") @db.Char(26)
  displayName  String   @default("") @map("display_name") @db.VarChar(50)
  avatarConfig Json?    @map("avatar_config") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, userId])
  @@map("profiles")
}
